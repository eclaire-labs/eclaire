{
  "name": "@eclaire/ai",
  "version": "0.0.0",
  "private": true,
  "description": "Unified AI client for Eclaire - multi-provider support with adapters",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome lint ./ && oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "biome format --write ./",
    "check": "biome check ./",
    "fix": "biome check --write ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "echo 'Usage: pnpm test:integration:local or pnpm test:integration:openrouter' && exit 1",
    "test:integration:local": "AI_TEST_PROVIDER=local vitest run",
    "test:integration:openrouter": "AI_TEST_PROVIDER=openrouter vitest run",
    "test:all": "vitest run && AI_TEST_PROVIDER=local vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "async-mutex": "0.5.0",
    "tiktoken": "1.0.22"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  }
}
