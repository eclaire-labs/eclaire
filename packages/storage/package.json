{
  "name": "@eclaire/storage",
  "version": "0.1.0",
  "description": "Storage abstraction with local filesystem and in-memory backends, zero-dependency core",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "storage",
    "filesystem",
    "object-storage",
    "s3",
    "abstraction"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eclaire-labs/eclaire",
    "directory": "packages/storage"
  },
  "files": [
    "dist"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "development": "./src/core/index.ts",
      "types": "./src/core/index.ts",
      "default": "./dist/core/index.js"
    },
    "./keys": {
      "development": "./src/keys/index.ts",
      "types": "./src/keys/index.ts",
      "default": "./dist/keys/index.js"
    },
    "./local": {
      "development": "./src/adapters/local/index.ts",
      "types": "./src/adapters/local/index.ts",
      "default": "./dist/adapters/local/index.js"
    },
    "./memory": {
      "development": "./src/adapters/memory/index.ts",
      "types": "./src/adapters/memory/index.ts",
      "default": "./dist/adapters/memory/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome lint ./ && oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "biome format --write ./",
    "check": "biome check ./",
    "fix": "biome check --write ./",
    "test": "vitest run",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.0.18"
  }
}
