{
  "name": "@eclaire/storage",
  "version": "0.0.0",
  "private": true,
  "description": "Storage abstraction - local filesystem and S3-compatible backends with zero-dependency core",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "development": "./src/core/index.ts",
      "types": "./src/core/index.ts",
      "default": "./dist/core/index.js"
    },
    "./local": {
      "development": "./src/adapters/local/index.ts",
      "types": "./src/adapters/local/index.ts",
      "default": "./dist/adapters/local/index.js"
    },
    "./memory": {
      "development": "./src/adapters/memory/index.ts",
      "types": "./src/adapters/memory/index.ts",
      "default": "./dist/adapters/memory/index.js"
    },
    "./s3": {
      "development": "./src/adapters/s3/index.ts",
      "types": "./src/adapters/s3/index.ts",
      "default": "./dist/adapters/s3/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome lint ./ && oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "biome format --write ./",
    "check": "biome check ./",
    "fix": "biome check --write ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@eclaire/logger": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.0.18"
  }
}
