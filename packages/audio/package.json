{
  "name": "@eclaire/audio",
  "version": "0.0.0",
  "private": true,
  "description": "Audio provider abstraction for STT/TTS via mlx-audio",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist",
    "lint": "oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fix": "oxlint --fix --tsconfig ../../tsconfig.oxlint.json . && oxfmt ."
  },
  "dependencies": {
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "8.18.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.1.5"
  }
}
