{
  "name": "@eclaire/core",
  "version": "0.0.0",
  "private": true,
  "description": "Core utilities for Eclaire applications - ID generation, encryption, types",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./id": {
      "development": "./src/id-generator.ts",
      "types": "./src/id-generator.ts",
      "default": "./dist/id-generator.js"
    },
    "./encryption": {
      "development": "./src/encryption.ts",
      "types": "./src/encryption.ts",
      "default": "./dist/encryption.js"
    },
    "./types": {
      "development": "./src/types.ts",
      "types": "./src/types.ts",
      "default": "./dist/types.js"
    },
    "./utils": {
      "development": "./src/utils.ts",
      "types": "./src/utils.ts",
      "default": "./dist/utils.js"
    },
    "./slash": {
      "development": "./src/slash.ts",
      "types": "./src/slash.ts",
      "default": "./dist/slash.js"
    },
    "./env-loader": {
      "development": "./src/env-loader.ts",
      "types": "./src/env-loader.ts",
      "default": "./dist/env-loader.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fix": "oxlint --fix --tsconfig ../../tsconfig.oxlint.json . && oxfmt ."
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "nanoid": "5.1.9"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.1.5"
  }
}
