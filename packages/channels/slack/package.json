{
  "name": "@eclaire/channels-slack",
  "version": "0.0.0",
  "private": true,
  "description": "Slack channel adapter for Eclaire",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "oxlint --tsconfig ../../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fix": "oxlint --fix --tsconfig ../../../tsconfig.oxlint.json . && oxfmt ."
  },
  "dependencies": {
    "@eclaire/channels-core": "workspace:*",
    "@eclaire/core": "workspace:*",
    "@slack/bolt": "4.7.1",
    "@slack/web-api": "7.15.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.1.5",
    "zod": "4.4.1"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
