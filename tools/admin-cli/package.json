{
  "name": "@eclaire/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Eclaire Admin CLI - Manage providers, models, and configuration",
  "main": "dist/main.js",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclaire-labs/eclaire.git",
    "directory": "tools/admin-cli"
  },
  "bugs": {
    "url": "https://github.com/eclaire-labs/eclaire/issues"
  },
  "homepage": "https://eclaire.co/",
  "bin": {
    "eclaire": "./dist/main.js",
    "cli": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx main.ts",
    "lint": "biome lint ./ && oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "biome format --write ./",
    "check": "biome check ./",
    "fix": "biome check --write ./",
    "test": "node test.js",
    "link": "pnpm link",
    "unlink": "pnpm unlink -g @eclaire/cli",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "models",
    "providers",
    "cli",
    "admin",
    "huggingface",
    "openrouter",
    "management"
  ],
  "author": "Eclaire Labs",
  "license": "MIT",
  "dependencies": {
    "@eclaire/ai": "workspace:*",
    "@eclaire/logger": "workspace:*",
    "axios": "1.13.6",
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "inquirer": "13.3.0",
    "ora": "9.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/inquirer": "9.0.9",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsx": "4.21.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^24.0.0"
  }
}
