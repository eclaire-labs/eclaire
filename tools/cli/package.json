{
  "name": "@eclaire/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Eclaire CLI - Manage providers, models, channels, and chat with AI",
  "keywords": [
    "admin",
    "ai",
    "cli",
    "huggingface",
    "management",
    "models",
    "openrouter",
    "providers"
  ],
  "homepage": "https://eclaire.co/",
  "bugs": {
    "url": "https://github.com/eclaire-labs/eclaire/issues"
  },
  "license": "MIT",
  "author": "Eclaire Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclaire-labs/eclaire.git",
    "directory": "tools/cli"
  },
  "bin": {
    "cli": "./dist/main.js",
    "eclaire": "./dist/main.js"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx main.ts",
    "lint": "oxlint --tsconfig ../../tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fix": "oxlint --fix --tsconfig ../../tsconfig.oxlint.json . && oxfmt .",
    "test": "node test.js",
    "link": "pnpm link",
    "unlink": "pnpm unlink -g @eclaire/cli",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.3.0",
    "@eclaire/ai": "workspace:*",
    "@eclaire/channels-core": "workspace:*",
    "@eclaire/channels-discord": "workspace:*",
    "@eclaire/channels-slack": "workspace:*",
    "@eclaire/channels-telegram": "workspace:*",
    "@eclaire/core": "workspace:*",
    "@eclaire/db": "workspace:*",
    "@eclaire/logger": "workspace:*",
    "axios": "1.15.2",
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "drizzle-orm": "0.45.2",
    "ink": "7.0.1",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "marked": "18.0.2",
    "nanoid": "5.1.9",
    "ora": "9.4.0",
    "react": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "19.2.14",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsx": "4.21.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@11.0.1"
}
