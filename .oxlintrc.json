{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "react",
    "jsx-a11y",
    "import",
    "unicorn",
    "typescript",
    "oxc",
    "vitest",
    "promise",
    "node"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    // ── TypeScript ────────────────────────────────────────────────
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-extraneous-class": "off",
    "no-unused-vars": "error",

    // ── React ──────────────────────────────────────────────────────
    // Not needed with React 17+ JSX transform
    "react/react-in-jsx-scope": "off",
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",

    // ── Unicorn ────────────────────────────────────────────────────
    // Slack SDK chat.postMessage() false positive
    "unicorn/require-post-message-target-origin": "off",
    "unicorn/no-useless-spread": "warn",
    "unicorn/no-useless-fallback-in-spread": "warn",
    "unicorn/prefer-array-flat-map": "warn",
    "unicorn/prefer-array-flat": "warn",
    "unicorn/prefer-array-some": "warn",
    "unicorn/no-single-promise-in-promise-methods": "warn",
    "unicorn/prefer-add-event-listener": "off",
    // Noisy with React component patterns
    "unicorn/consistent-function-scoping": "off",
    // Drizzle ORM query builders implement .then() for await support
    "unicorn/no-thenable": "off",

    // ── Promise ────────────────────────────────────────────────────
    "promise/no-new-statics": "warn",
    "promise/valid-params": "warn",
    "promise/no-multiple-resolved": "warn",
    // Codebase uses async/await, not .then() chains
    "promise/always-return": "off",

    // ── Import ─────────────────────────────────────────────────────
    "import/no-self-import": "warn",
    // TypeScript handles module resolution
    "import/no-named-as-default-member": "off",
    "import/no-cycle": "off",
    "import/default": "off",
    "import/named": "off",
    "import/namespace": "off",
    "import/no-unassigned-import": "off",

    // ── Suspicious: justified to keep off ───────────────────────────
    "no-new": "off",
    "no-underscore-dangle": "off",
    "no-this-alias": "off",
    "oxc/no-map-spread": "off",
    // Sequential awaits are intentional in queue workers, agent loops, and tests
    "no-await-in-loop": "off",

    // ── Suspicious ────────────────────────────────────────────────────
    // 93% benign (React Query error destructuring, Drizzle re-imports, callbacks); no allow-list support
    "no-shadow": "off",

    // ── Perf: promoted to error ─────────────────────────────────────
    "react/no-array-index-key": "error",

    // ── Vitest ──────────────────────────────────────────────────────
    "vitest/no-disabled-tests": "warn",
    // 566 findings — impractical to enforce across all vi.fn() calls
    "vitest/require-mock-type-parameters": "off",

    // ── Jest: disabled (test runner is vitest, not jest) ────────────
    "jest/no-conditional-expect": "off",
    "jest/valid-expect": "off",
    "jest/no-standalone-expect": "off",
    "jest/expect-expect": "off",
    "jest/valid-describe-callback": "off",
    "jest/no-disabled-tests": "off",
    "jest/require-to-throw-message": "off",
    "jest/no-export": "off",
    "jest/no-focused-tests": "off",
    "jest/prefer-snapshot-hint": "off",
    "jest/valid-expect-in-promise": "off",
    "jest/valid-title": "off",
    "jest/no-commented-out-tests": "off",

    // ── JSX a11y ───────────────────────────────────────────────────
    "jsx-a11y/prefer-tag-over-role": "warn",
    // UX decision for productivity app
    "jsx-a11y/no-autofocus": "off",
    "jsx-a11y/no-static-element-interactions": "warn",
    "jsx-a11y/click-events-have-key-events": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/tests/**", "**/testkit/**"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-non-null-asserted-optional-chain": "off",
        // Common pattern in integration tests: if (result.field) { expect(result.field)... }
        "vitest/no-conditional-expect": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/.next",
    "**/data",
    "**/build",
    "apps/frontend/public/sw.js",
    "apps/frontend/public/workbox-*.js",
    "apps/frontend/src/routeTree.gen.ts",
    "snippets/**"
  ]
}
