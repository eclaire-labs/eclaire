{
  "name": "@eclaire/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "NODE_ENV=development tsc && cp src/connect.html dist/connect.html && cp -r resources dist/resources && NODE_ENV=development electron dist/main.js",
    "build": "tsc && cp src/connect.html dist/connect.html && cp -r resources dist/resources",
    "pack": "tsc && electron-builder --dir",
    "dist": "tsc && electron-builder",
    "dist:mac": "tsc && electron-builder --mac",
    "dist:win": "tsc && electron-builder --win",
    "dist:linux": "tsc && electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "fix": "oxlint --fix src/ && oxfmt src/"
  },
  "dependencies": {
    "electron-store": "11.0.2",
    "electron-updater": "6.8.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "productName": "Eclaire"
}
