{
  "name": "@eclaire/monorepo",
  "version": "0.7.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "license": "MIT",
  "description": "Eclaire - AI-powered productivity platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclaire-labs/eclaire.git"
  },
  "bugs": {
    "url": "https://github.com/eclaire-labs/eclaire/issues"
  },
  "homepage": "https://eclaire.co/",
  "engines": {
    "node": "^24.0.0"
  },
  "pnpm": {
    "overrides": {
      "npm-run-path": "5.3.0",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.5",
      "minimatch": ">=10.2.3",
      "tar": ">=7.5.11"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@playwright/test": "1.58.2",
    "node-addon-api": "8.6.0",
    "node-gyp": "12.2.0",
    "oxlint": "catalog:"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "setup:dev": "node scripts/setup.js",
    "setup:clean": "node scripts/setup-clean.js",
    "dev": "pnpm dev:backend & pnpm dev:frontend",
    "dev:backend": "cd apps/backend && pnpm dev",
    "dev:backend:nowatch": "cd apps/backend && pnpm dev:nowatch",
    "dev:frontend": "cd apps/frontend && pnpm dev",
    "build": "pnpm -r build",
    "clean:all": "pnpm -r clean && find . -name '*.tsbuildinfo' -type f -delete && rm -rf node_modules apps/*/node_modules packages/*/node_modules tools/*/node_modules",
    "test": "pnpm test:unit",
    "test:unit": "pnpm --filter @eclaire/core test && pnpm --filter @eclaire/audio test && pnpm --filter @eclaire/backend test && pnpm --filter @eclaire/frontend test && pnpm --filter @eclaire/ai test && pnpm --filter @eclaire/queue test",
    "test:integration": "echo 'Run a specific integration suite: test:integration:api, test:integration:ai:local, etc.' && exit 1",
    "test:integration:api": "pnpm --filter @eclaire/backend test:integration",
    "test:integration:channels": "pnpm --filter @eclaire/backend test:integration:channels",
    "test:integration:api:start": "./scripts/integration-api-start.sh",
    "test:integration:ai:local": "pnpm --filter @eclaire/ai test:integration:local",
    "test:integration:audio": "pnpm --filter @eclaire/audio test:integration",
    "test:integration:ai:openrouter": "pnpm --filter @eclaire/ai test:integration:openrouter",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/e2e/playwright.config.ts --ui",
    "lint": "pnpm lint:biome && pnpm lint:oxlint",
    "lint:biome": "biome lint ./",
    "lint:oxlint": "oxlint --tsconfig tsconfig.oxlint.json --max-warnings=0 --report-unused-disable-directives apps packages tools scripts",
    "format": "biome format --write ./",
    "check": "biome check ./",
    "fix": "biome check --write ./",
    "typecheck": "pnpm -r typecheck",
    "typecheck:backend": "pnpm --filter @eclaire/backend typecheck",
    "typecheck:frontend": "pnpm --filter @eclaire/frontend typecheck",
    "config:show": "pnpm --filter @eclaire/backend config:show",
    "app:upgrade": "pnpm --filter @eclaire/backend app:upgrade",
    "app:upgrade-check": "pnpm --filter @eclaire/backend app:upgrade-check",
    "cli": "pnpm --filter @eclaire/cli exec tsx main.ts",
    "eclaire": "pnpm --filter @eclaire/cli exec tsx main.ts"
  }
}
